# Copy this file to ".env" for local integration.
# The backend reads both ".env" and "backend/.env".
# The dev scripts also source ".env" so the web and server processes share one set of values.

# Service ports and local URLs
PSOP_SERVER_HOST=0.0.0.0
PSOP_SERVER_PORT=8011
PSOP_WEB_HOST=0.0.0.0
PSOP_WEB_PORT=4173
PSOP_WEB_API_BASE_URL=http://127.0.0.1:8011/api/v1

# Backend startup behavior
PSOP_DATABASE_CHECK_ON_STARTUP=true
PSOP_DATABASE_AUTO_CREATE_SCHEMA=true
PSOP_CORS_ALLOW_ORIGINS='["*"]'

# PostgreSQL connection
# You may also replace the fields below with PSOP_DATABASE_URL.
# Example:
# PSOP_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/psop
PSOP_DATABASE_HOST=127.0.0.1
PSOP_DATABASE_PORT=5432
PSOP_DATABASE_NAME=psop
PSOP_DATABASE_USER=postgres
PSOP_DATABASE_PASSWORD=postgres

# GitLab integration
PSOP_GITLAB_API_BASE_URL=https://gitlab.com/api/v4
PSOP_GITLAB_TOKEN=replace-with-your-gitlab-token
PSOP_GITLAB_SKILLS_GROUP_PATH=skills
PSOP_GITLAB_DEFAULT_BRANCH=main
PSOP_GITLAB_TIMEOUT_SECONDS=15

# Object store / MinIO
PSOP_OBJECT_STORE_ENDPOINT=http://127.0.0.1:9000
PSOP_OBJECT_STORE_ACCESS_KEY=minioadmin
PSOP_OBJECT_STORE_SECRET_KEY=minioadmin
PSOP_OBJECT_STORE_BUCKET=psop-artifacts
PSOP_OBJECT_STORE_REGION=us-east-1
PSOP_OBJECT_STORE_SECURE=false

# Raw material upload limits
PSOP_RAW_MATERIAL_MAX_UPLOAD_BYTES=52428800
PSOP_RAW_MATERIAL_VIDEO_MAX_UPLOAD_BYTES=2147483648
PSOP_VIDEO_MAX_ANALYZED_FRAMES=120

# OpenTelemetry
PSOP_LOG_FORMAT=json
NO_PROXY=127.0.0.1,localhost,::1,10.0.0.15
no_proxy=127.0.0.1,localhost,::1,10.0.0.15
PSOP_OTEL_ENABLED=true
PSOP_OTEL_TRACES_ENABLED=true
PSOP_OTEL_LOGS_ENABLED=true
PSOP_OTEL_CONSOLE_EXPORTER=false
PSOP_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
PSOP_OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
PSOP_OTEL_SERVICE_NAME=psop-backend

# LLM Inference Gateway
PSOP_LLM_PROVIDER=openai-compatible
PSOP_LLM_API_BASE_URL=https://api.openai.com/v1
PSOP_LLM_API_KEY=replace-with-your-llm-api-key
PSOP_LLM_TEXT_MODEL=qwen3.7-plus
PSOP_LLM_TEXT_ENABLE_THINKING=true
PSOP_LLM_TEXT_THINKING_BUDGET=8192
PSOP_LLM_MULTIMODAL_MODEL=qwen3.6-plus
PSOP_LLM_MULTIMODAL_ENABLE_THINKING=true
PSOP_LLM_MULTIMODAL_THINKING_BUDGET=8192
PSOP_LLM_TIMEOUT_SECONDS=600

# LightRAG industry standard search
PSOP_STANDARD_LIGHTRAG_BASE_URL=http://10.0.0.20:9621
PSOP_STANDARD_LIGHTRAG_API_KEY=servforce
PSOP_STANDARD_LIGHTRAG_TIMEOUT_SECONDS=20
PSOP_STANDARD_LIGHTRAG_MAX_RESULTS=8

# ASR Gateway for video raw material analysis
PSOP_ASR_API_BASE_URL=http://10.0.0.20:12302
PSOP_ASR_LANGUAGE=zh
PSOP_ASR_TIMEOUT_SECONDS=600
PSOP_ASR_TEMPERATURE=0

# Runtime worker
PSOP_RUNTIME_WORKER_ENABLED=true
PSOP_RUNTIME_JOB_LEASE_SECONDS=60
PSOP_RUNTIME_JOB_MAX_ATTEMPTS=3
PSOP_RUNTIME_STEP_TIMEOUT_SECONDS=120

# Agent Harness
# 是否启用受治理的 Agent Harness，用于 builder/compiler/tester 等智能体。
PSOP_AGENT_HARNESS_ENABLED=true
# Harness 运行配置档。dev_open 允许 MVP demo 使用 workspace 内工具。
PSOP_AGENT_HARNESS_PROFILE=dev_open
# Agent Harness 沙箱 provider。首版 local 仅提供本地目录隔离，不是安全执行沙箱。
PSOP_AGENT_HARNESS_SANDBOX_PROVIDER=local
# 每次 agent run 的 sandbox、事件日志、memory 与输出根目录。
PSOP_AGENT_HARNESS_SANDBOX_ROOT=.psop/agent-runs
# 是否启用 MCP tool adapter；配置可信 MCP server 前默认关闭。
PSOP_AGENT_HARNESS_MCP_ENABLED=false
