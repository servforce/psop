# Copy this file to ".env" for local integration.
# The backend reads both ".env" and "backend/.env".
# The dev scripts also source ".env" so the web and server processes share one set of values.

# Service ports and local URLs
PSOP_SERVER_HOST=0.0.0.0
PSOP_SERVER_PORT=8001
PSOP_WEB_HOST=0.0.0.0
PSOP_WEB_PORT=4173
PSOP_WEB_API_BASE_URL=http://127.0.0.1:8001/api/v1

# Backend startup behavior
PSOP_DATABASE_CHECK_ON_STARTUP=true
PSOP_DATABASE_AUTO_CREATE_SCHEMA=true
PSOP_CORS_ALLOW_ORIGINS='["*"]'

# PostgreSQL connection
# You may also replace the fields below with PSOP_DATABASE_URL.
# Example:
# PSOP_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/psop
PSOP_DATABASE_HOST=127.0.0.1
PSOP_DATABASE_PORT=5432
PSOP_DATABASE_NAME=psop
PSOP_DATABASE_USER=postgres
PSOP_DATABASE_PASSWORD=postgres

# GitLab integration
PSOP_GITLAB_API_BASE_URL=https://gitlab.com/api/v4
PSOP_GITLAB_TOKEN=replace-with-your-gitlab-token
PSOP_GITLAB_SKILLS_GROUP_PATH=skills
PSOP_GITLAB_DEFAULT_BRANCH=main
PSOP_GITLAB_TIMEOUT_SECONDS=15
