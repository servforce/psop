# =========================
# 应用基础配置
# =========================
# 服务名称，会显示在健康检查与 OpenAPI 文档中。
PSOP_APP_NAME=PSOP Server
# 服务版本号。
PSOP_APP_VERSION=0.1.0
# 运行环境：development / test / production。
PSOP_ENVIRONMENT=development
# 是否开启调试模式。
PSOP_DEBUG=true
# API 前缀。
PSOP_API_PREFIX=/api/v1
# 日志级别：DEBUG / INFO / WARNING / ERROR。
PSOP_LOG_LEVEL=INFO
# 允许跨域访问的前端地址，使用 JSON 数组格式。
PSOP_CORS_ALLOW_ORIGINS=["http://127.0.0.1:4173","http://localhost:4173"]
